# Copy this file to `.env` and fill in the values.
# Do NOT commit `.env`.

# Supabase Postgres — transaction pooler (port 6543).
# Used at runtime by the Prisma driver adapter.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Supabase Postgres — direct/session connection (port 5432).
# Used by the Prisma CLI for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase project (Storage uploads). Find both in:
# Dashboard -> Project Settings -> API (Project URL + anon/publishable key).
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
